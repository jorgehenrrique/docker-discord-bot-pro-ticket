# === Discord (obrigatório no primeiro deploy) ===
BOT_TOKEN=
GUILD_ID=
DISCORD_CLIENT_SECRET=

# === Ambiente HTTP / painel web ===
NODE_ENV=production
PORT=8080
# Railway: use o domínio público gerado (Networking). Local: http://localhost:8080
BASE_URL=https://SUBSTITUA_PELO_SEU_DOMINIO.up.railway.app
SERVER_HOSTNAME=SUBSTITUA_PELO_SEU_DOMINIO.up.railway.app

# === Steam (opcional — avatares na verificação Steam) ===
STEAM_API_KEY=

# === MongoDB ===
# Railway: referencie a variável do serviço MongoDB (ex.: ${{Mongo.MONGO_URL}} ou equivalente no dashboard).
# Local (docker compose): credenciais devem coincidir com mongo no docker-compose.yml
MONGO_URI=mongodb://root:changeme@mongo:27017/?authSource=admin
MONGO_DB_TICKET=pro_ticket
COLLECTION_SYSTEM_SETTINGS=system_settings
COLLECTION_VERIFIED_USERS=verified_users
COLLECTION_TICKETS=tickets
COLLECTION_TICKET_USERS=ticket_users